# =============================================================================
# Lehman_Cousins — .gitignore (strict, exhaustive)
# =============================================================================

# ---------------------------------------------------------------------------
# 🔐 SECRETS — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example          # The template is safe to commit
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ---------------------------------------------------------------------------
# Rust / Cargo build artefacts
# ---------------------------------------------------------------------------
/target/
debug/
release/
**/*.rs.bk             # rustfmt backup files
# (Cargo.lock should be committed for binary crates)

# ---------------------------------------------------------------------------
# Logs & local data
# ---------------------------------------------------------------------------
*.log
*.log.*
logs/
ticks/
data/

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.iml
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.dockerignore*

# ---------------------------------------------------------------------------
# Python (tooling, notebooks)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/
*.ipynb_checkpoints

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
*.bak
*.tmp
*.temp

# ---------------------------------------------------------------------------
# Benchmark / profiling output
# ---------------------------------------------------------------------------
flamegraph.svg
perf.data
perf.data.old
criterion/
